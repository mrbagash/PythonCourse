{
  "rules": {
    ".read": false,
    ".write": false,

    "admins": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.token.firebase.sign_in_provider === 'google.com' && (root.child('admins').child(auth.uid).val() === true || ((auth.uid === 'OSyDoCzzush3n94fDG6tyvzDsf93' || auth.uid === 'V3q0I1cfjjOrVSJJNZHHbdt4tsB3') && $uid === auth.uid))",
        ".validate": "newData.val() === true"
      }
    },

    "teacherSessions": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid && (!newData.exists() || (newData.child('code').isString() && root.child('teachers').child(newData.child('code').val()).exists()))",
        ".validate": "!newData.exists() || newData.hasChildren(['code', 'loggedInAt'])"
      }
    },

    "studentSessions": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid && (!newData.exists() || (newData.child('code').isString() && ((root.child('studentCodes').child(newData.child('code').val()).exists()) || (newData.child('codeLower').isString() && root.child('codeIndex').child(newData.child('codeLower').val()).child('storedCode').val() === newData.child('code').val()))))",
        ".validate": "!newData.exists() || (newData.hasChildren(['code', 'codeLower', 'className', 'loggedInAt']) && ((newData.child('className').val() === root.child('studentCodes').child(newData.child('code').val()).child('className').val()) || (newData.child('className').val() === root.child('codeIndex').child(newData.child('codeLower').val()).child('className').val() && root.child('codeIndex').child(newData.child('codeLower').val()).child('storedCode').val() === newData.child('code').val())))"
      }
    },

    "classNames": {
      ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
      ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())"
    },

    "classes": {
      ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
      ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
      "$className": {
        "forcedQuiz": {
          ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists() || root.child('studentSessions').child(auth.uid).child('className').val() === $className)",
          ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())"
        },
        "apFeedback": {
          ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists() || root.child('studentSessions').child(auth.uid).child('className').val() === $className)",
          ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())"
        },
        "forcedAPAssignments": {
          "$studentCode": {
            ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists() || (root.child('studentSessions').child(auth.uid).child('className').val() === $className && root.child('studentSessions').child(auth.uid).child('code').val() === $studentCode))",
            ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists() || (root.child('studentSessions').child(auth.uid).child('className').val() === $className && root.child('studentSessions').child(auth.uid).child('code').val() === $studentCode))"
          }
        }
      }
    },

    "codeIndex": {
      ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
      ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
      "$codeLower": {
        ".read": "auth != null"
      }
    },

    "studentCodes": {
      ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
      ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
      "$studentCode": {
        ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists() || root.child('studentSessions').child(auth.uid).child('code').val() === $studentCode)"
      }
    },

    "teachers": {
      ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
      ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teachers').child(root.child('teacherSessions').child(auth.uid).child('code').val()).child('permissions').child('fullAdmin').val() === true || root.child('teachers').child(root.child('teacherSessions').child(auth.uid).child('code').val()).child('permissions').child('manageTeachers').val() === true)",
      "$teacherCode": {
        ".read": "auth != null",
        ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teachers').child(root.child('teacherSessions').child(auth.uid).child('code').val()).child('permissions').child('fullAdmin').val() === true || root.child('teachers').child(root.child('teacherSessions').child(auth.uid).child('code').val()).child('permissions').child('manageTeachers').val() === true)"
      }
    },

    "activeSessions": {
      ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
      ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())"
    },

    "progress": {
      ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
      ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
      "$studentCode": {
        ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists() || root.child('studentSessions').child(auth.uid).child('code').val() === $studentCode)",
        ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists() || root.child('studentSessions').child(auth.uid).child('code').val() === $studentCode)"
      }
    },

    "quizSessions": {
      ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
      ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
      "$lobbyCode": {
        ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists() || root.child('studentSessions').child(auth.uid).exists())",
        ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
        "players": {
          "$studentCode": {
            ".write": "auth != null && root.child('studentSessions').child(auth.uid).child('code').val() === $studentCode"
          }
        },
        "answers": {
          "$questionIdx": {
            "$studentCode": {
              ".write": "auth != null && root.child('studentSessions').child(auth.uid).child('code').val() === $studentCode"
            }
          }
        }
      }
    },

    "buildBattles": {
      ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
      ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
      "$code": {
        ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists() || root.child('studentSessions').child(auth.uid).exists())",
        ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
        "players": {
          "$studentCode": {
            ".write": "auth != null && root.child('studentSessions').child(auth.uid).child('code').val() === $studentCode"
          }
        },
        "submissions": {
          "$studentCode": {
            ".write": "auth != null && root.child('studentSessions').child(auth.uid).child('code').val() === $studentCode",
            "model": { ".validate": "newData.isString() && newData.val().length < 800000" }
          }
        },
        "votes": {
          "$voterCode": {
            ".write": "auth != null && root.child('studentSessions').child(auth.uid).child('code').val() === $voterCode",
            "$targetCode": {
              ".validate": "$voterCode !== $targetCode && newData.isNumber() && newData.val() >= 1 && newData.val() <= 5"
            }
          }
        },
        "reactions": {
          ".write": "auth != null && root.child('studentSessions').child(auth.uid).exists()",
          "$reactionId": {
            ".validate": "newData.hasChild('e') && newData.child('e').isString() && newData.child('e').val().length <= 8"
          }
        }
      }
    },

    "buildBattlesSandbox": {
      ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
      ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
      "$code": {
        ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists() || root.child('studentSessions').child(auth.uid).exists())",
        ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
        "players": {
          "$studentCode": {
            ".write": "auth != null && root.child('studentSessions').child(auth.uid).child('code').val() === $studentCode"
          }
        },
        "submissions": {
          "$studentCode": {
            ".write": "auth != null && root.child('studentSessions').child(auth.uid).child('code').val() === $studentCode",
            "model": { ".validate": "newData.isString() && newData.val().length < 800000" }
          }
        },
        "votes": {
          "$voterCode": {
            ".write": "auth != null && root.child('studentSessions').child(auth.uid).child('code').val() === $voterCode",
            "$targetCode": {
              ".validate": "$voterCode !== $targetCode && newData.isNumber() && newData.val() >= 1 && newData.val() <= 5"
            }
          }
        },
        "reactions": {
          ".write": "auth != null && root.child('studentSessions').child(auth.uid).exists()",
          "$reactionId": {
            ".validate": "newData.hasChild('e') && newData.child('e').isString() && newData.child('e').val().length <= 8"
          }
        }
      }
    },

    "accessLog": {
      ".indexOn": ["lastSeen"],
      ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())",
      "$studentCode": {
        ".write": "auth != null && root.child('studentSessions').child(auth.uid).child('code').val() === $studentCode"
      }
    },

    "apFeedback": {
      ".read": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists() || root.child('studentSessions').child(auth.uid).exists())",
      ".write": "auth != null && ((auth.token.firebase.sign_in_provider === 'google.com' && root.child('admins').child(auth.uid).val() === true) || root.child('teacherSessions').child(auth.uid).exists())"
    }
  }
}
